# Required
SECRET_KEY_BASE=change-me-generate-with-bin-rails-secret
DATABASE_URL=postgres://postgres@localhost:5432/spree_production
REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_URL=redis://localhost:6380/0  # dedicated cache Redis (falls back to REDIS_URL)

# Web Server
PORT=3000
# RAILS_MAX_THREADS=3
# WEB_CONCURRENCY=1

# SSL (defaults to true in production — set to false for local dev or non-SSL proxies)
# RAILS_FORCE_SSL=false
# RAILS_ASSUME_SSL=false

# Email (SMTP) — set SMTP_HOST to enable email delivery, otherwise emails are logged
# SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
# SMTP_PORT=2587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=store@example.com
# Production only: used as the host for URLs generated in emails.
# RAILS_HOST=example.com

# Storefront URL — used by the admin "View Store" link.
# Defaults to http://localhost:3000 if not set.
# FRONTEND_URL=https://minimeshop.net

# File Storage — auto-detected from credentials, falls back to local disk
# DigitalOcean Spaces (single bucket for dev+prod, folder prefix via storage.yml)
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_BUCKET=minimeshop-bucket
# DO_SPACES_REGION=sgp1
# DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# DO_SPACES_PREFIX=dev  # auto-set to "dev" or "prod" based on Rails.env if omitted
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=spree-production

# Cloudflare R2
# CLOUDFLARE_ENDPOINT=
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKET=spree-production

# Error Tracking
# SENTRY_DSN=

# Application
# RAILS_ENV=production
# RAILS_LOG_LEVEL=info

# Search
# MEILISEARCH_URL=
# MEILISEARCH_API_KEY=

# Spree core development — set to path of spree monorepo to use local gems
# SPREE_PATH=../spree
