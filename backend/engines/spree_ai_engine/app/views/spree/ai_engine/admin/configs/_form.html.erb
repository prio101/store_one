<%= form_for config, url: (config.persisted? ? admin_ai_engine_config_path(config) : admin_ai_engine_configs_path), method: (config.persisted? ? :patch : :post) do |f| %>
  <% if config.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(config.errors.count, "error") %> prohibited this configuration from being saved:</h5>
      <ul class="mb-0">
        <% config.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend class="w-full form-label text-lg font-bold border-b border-gray-300 rounded-lg p-2">Status</legend>
    <div class="form-group">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, "Active", class: "form-check-label" %>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend class="w-full form-label text-lg font-bold border-b border-gray-300 rounded-lg p-2">Provider Settings</legend>
    <div class="form-group">
      <%= f.label :store_id, "Store" %>
      <%= f.collection_select :store_id, Spree::Store.all, :id, :name, {}, { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= f.label :provider, "Provider" %>
      <%= f.select :provider, [["Google Gemini", "gemini"], ["OpenAI", "openai"]], {}, { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= f.label :api_key, "API Key" %>
      <% if config.persisted? && config.api_key.present? %>
        <%= f.password_field :api_key, class: "form-control", placeholder: "Leave blank to keep existing" %>
        <small class="form-text text-muted">API key is stored encrypted. Leave blank to keep the existing key.</small>
      <% else %>
        <%= f.password_field :api_key, class: "form-control" %>
      <% end %>
    </div>
  </fieldset>

  <fieldset>
    <legend class="w-full form-label text-lg font-bold border-b border-gray-300 rounded-lg p-2">Model Defaults</legend>
    <div class="form-group">
      <%= f.label :ai_model_name, "Model Name" %>
      <%= f.text_field :ai_model_name, class: "form-control", placeholder: "e.g. gemini-2.0-flash" %>
    </div>

    <div class="form-group">
      <%= f.label :temperature, "Temperature" %>
      <%= f.number_field :temperature, class: "form-control", step: 0.1, min: 0.0, max: 2.0 %>
      <small class="form-text text-muted">Controls randomness. Lower = more focused, higher = more creative. Range: 0.0–2.0</small>
    </div>

    <div class="form-group">
      <%= f.label :max_output_tokens, "Max Output Tokens" %>
      <%= f.number_field :max_output_tokens, class: "form-control", min: 1 %>
    </div>
  </fieldset>

  <fieldset>
    <legend class="w-full form-label text-lg font-bold border-b border-gray-300 rounded-lg p-2">Prompt Templates</legend>
    <div class="form-group">
      <%= f.label :system_prompt, "System Prompt" %>
      <%= f.text_area :system_prompt, class: "form-control", rows: 4, placeholder: "Instructions for AI behavior (e.g. 'You are a product copywriter for an e-commerce store...')" %>
    </div>

    <% if config.persisted? %>
      <div class="mt-3">
        <%= link_to "Manage Work Tasks & Prompts →",
                    admin_ai_engine_config_ai_engine_work_tasks_path(config),
                    class: "text-blue-600 hover:underline font-medium" %>
        <small class="form-text text-muted d-block">Define work tasks (product description, SEO, etc.) and their prompt templates.</small>
      </div>
    <% end %>
  </fieldset>

  <fieldset>
    <legend class="w-full form-label text-lg font-bold border-b border-gray-600 rounded-lg p-2">Rate Limits & Logging</legend>
    <div class="form-group">
      <%= f.label :rate_limit_rpm, "Rate Limit (Requests per Minute)" %>
      <%= f.number_field :rate_limit_rpm, class: "form-control", min: 0 %>
      <small class="form-text text-muted">Leave empty for no limit.</small>
    </div>

    <div class="form-group">
      <div class="form-check">
        <%= f.check_box :logging_enabled, class: "form-check-input" %>
        <%= f.label :logging_enabled, "Enable Logging", class: "form-check-label" %>
      </div>
      <small class="form-text text-muted">Log API requests and responses for debugging.</small>
    </div>
  </fieldset>

  <div class="form-actions mt-4">
    <%= f.submit "Save Configuration", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_ai_engine_configs_path, class: "btn btn-secondary ms-2" %>
  </div>
<% end %>
