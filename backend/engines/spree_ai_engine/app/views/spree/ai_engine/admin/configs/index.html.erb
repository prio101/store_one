<% content_for :page_actions do %>
  <%= link_to "New Configuration", new_admin_ai_engine_config_path, class: "btn btn-primary" %>
<% end %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold">AI Engine Configurations</h1>

  <div class="flex items-center space-x-2 mb-4 mt-4">
    <%= link_to "New Configuration", new_admin_ai_engine_config_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @configs.any? %>
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Store</th>
        <th>Provider</th>
        <th>Model</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @configs.each do |config| %>
        <tr>
          <td><%= config.store&.name || "—" %></td>
          <td><%= config.provider_label %></td>
          <td><%= config.ai_model_name %></td>
          <td>
            <% if config.active? %>
              <span class="badge badge-success">Active</span>
            <% else %>
              <span class="badge badge-light">Inactive</span>
            <% end %>
          </td>
          <td>
            <%= link_to "Work Tasks", admin_ai_engine_config_ai_engine_work_tasks_path(config), class: "btn btn-sm btn-secondary" %>
            <%= link_to "Edit", edit_admin_ai_engine_config_path(config), class: "btn btn-sm btn-secondary" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="flex mt-2 p-2 items-center justify-center h-auto text-gray-500 text-lg font-semibold border border-dashed border-gray-300 rounded-lg">
    No AI Engine configurations found. Create one to get started.
  </div>
<% end %>
