<%# frozen_string_literal: true %>

<div class="card mt-4">
  <div class="card-header d-flex justify-content-between align-items-center mt-3">
    <h5 class="mb-0">Pathao Courier Configurations</h5>
    <%= link_to 'New Configuration', new_admin_pathao_courier_config_path, class: 'btn btn-primary btn-sm' %>
  </div>
  <div class="card-body">
    <% if @configs.any? %>
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Store</th>
            <th>Base URL</th>
            <th>Sandbox</th>
            <th>Delivery Type</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @configs.each do |config| %>
            <tr>
              <td><%= config.store&.name || config.store_id %></td>
              <td><%= config.base_url %></td>
              <td>
                <% if config.sandbox? %>
                  <span class="badge bg-warning text-white">Sandbox</span>
                <% else %>
                  <span class="badge bg-success text-white">Live</span>
                <% end %>
              </td>
              <td><%= config.delivery_type_name %></td>
              <td>
                <% if config.active? %>
                  <span class="badge bg-success text-white">Active</span>
                <% else %>
                  <span class="badge bg-secondary text-white">Inactive</span>
                <% end %>
              </td>
              <td>
                <%= link_to 'Edit', edit_admin_pathao_courier_config_path(config), class: 'btn btn-outline-secondary btn-sm' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted mb-0">No Pathao Courier configurations found. Click "New Configuration" to create one.</p>
    <% end %>
  </div>
</div>
